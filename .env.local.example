# Required for contact form email delivery
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address where contact form submissions are delivered
CONTACT_EMAIL=your@email.com

# Your site's public URL (used for canonical URLs, sitemap, and OG images)
# No trailing slash
NEXT_PUBLIC_SITE_URL=https://myaiway.com
